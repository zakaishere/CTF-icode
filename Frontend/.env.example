# Copy this file to .env and fill in your values.
# NEXT_PUBLIC_* vars are baked into the browser bundle at build time.

# URL of the backend API (no trailing slash)
# Dev default (Next.js proxy rewrites /api/* → this host):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Next.js telemetry — keep disabled unless you want to send usage data to Vercel
NEXT_TELEMETRY_DISABLED=1
