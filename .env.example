# Copy this file to .env and fill in every value marked REQUIRED.
# Values with defaults are optional — override only if needed.
#
# Quick start:
#   cp .env.example .env
#   # Fill in DB_PASSWORD, JWT_SECRET, CTF_FLAG_SECRET, CTF_INSTANCE_HOST
#   make up

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=icode_ctf
DB_USERNAME=icode_user
DB_PASSWORD=CHANGE_ME_REQUIRED          # REQUIRED — any strong password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_REQUIRED           # REQUIRED — app refuses to start without it
JWT_EXPIRY_MS=86400000                  # 24 hours

# Generate with: openssl rand -base64 32
CTF_FLAG_SECRET=CHANGE_ME_REQUIRED      # REQUIRED — derives per-team dynamic flags

# ── CTF platform ──────────────────────────────────────────────────────────────
# Public IP or hostname of the server where challenge instances run.
# Players connect here with nc/browser. REQUIRED for challenge instances to work.
CTF_INSTANCE_HOST=CHANGE_ME_REQUIRED

# Absolute path where challenge ZIP files are stored.
# Must be the same path on the host AND inside the backend container.
# Create it first: sudo mkdir -p /data/ctf-uploads && sudo chmod 777 /data/ctf-uploads
CTF_UPLOAD_PATH=/data/ctf-uploads

# Port range Docker assigns to challenge instances (host ports).
# Open these in your firewall so players can connect.
CTF_PORT_MIN=32000
CTF_PORT_MAX=33000

# ── Email (optional — disable for local dev) ──────────────────────────────────
# Set APP_SECURITY_DISABLE_VERIFICATION=true to skip OTP email in dev.
# NEVER set to true in production — students can register with fake emails.
APP_SECURITY_DISABLE_VERIFICATION=false

MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=
MAIL_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# In production set this to your public URL, e.g. https://ctf.myuniversity.ma
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Nginx ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Docker (single-machine default — no changes needed) ──────────────────────
# For a two-machine setup (platform on Machine 1, Docker worker on Machine 2)
# see IwillNeedThisForProduction.txt for full instructions.
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TLS_VERIFY=false
DOCKER_CERT_PATH=
