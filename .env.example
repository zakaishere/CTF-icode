# ═══════════════════════════════════════════════════════════════════════════
#  icode-ctf configuration
# ═══════════════════════════════════════════════════════════════════════════
#
#  LOCAL / FIRST-TIME USE: you don't need this file at all.
#    Just run:  docker compose up -d
#    Open:      http://localhost
#    Login:     admin@icode-ctf.local / Admin123!
#
#  PRODUCTION: copy this file and fill in the values below.
#    cp .env.example .env && nano .env && docker compose up -d --build
#
#  Anything you set here overrides the safe defaults baked into
#  docker-compose.yml. Anything you leave commented keeps its default.
# ═══════════════════════════════════════════════════════════════════════════

# ── PRODUCTION: required for challenge instances to be reachable ──────────────
# Public IP or domain players use to connect to challenge instances
# (e.g. nc <CTF_INSTANCE_HOST> 32001). Defaults to "localhost".
#CTF_INSTANCE_HOST=your.server.ip

# ── PRODUCTION: strongly recommended secrets ──────────────────────────────────
# Generate each with: openssl rand -base64 32
# (Dev defaults boot fine but are NOT safe for a public deployment.)
#JWT_SECRET=
#CTF_FLAG_SECRET=
#DB_PASSWORD=

# ── CORS — set to your real frontend origin in production ─────────────────────
#CORS_ALLOWED_ORIGINS=https://ctf.yourdomain.com

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave verification disabled (default) to let users register without SMTP,
# or configure a mailbox and turn it on:
#APP_SECURITY_DISABLE_VERIFICATION=false
#MAIL_HOST=smtp.gmail.com
#MAIL_USERNAME=
#MAIL_PASSWORD=

# ── Database (safe defaults used if unset) ────────────────────────────────────
#DB_NAME=icode_ctf
#DB_USERNAME=icode_user
#DB_PASSWORD=icode_local_dev_pass

# ── Ports ─────────────────────────────────────────────────────────────────────
#HTTP_PORT=80
#CTF_PORT_MIN=32000
#CTF_PORT_MAX=33000

# ── Upload path (must be identical on host and inside the backend container) ──
#CTF_UPLOAD_PATH=/data/ctf-uploads

# ── Worker Agent (set these if using a separate server for instances) ─────────
# Get values from icode-ctf-agent after running setup
#WORKER_AGENT_URL=http://YOUR_AGENT_SERVER_IP:8000
#WORKER_AGENT_KEY_ID=
#WORKER_AGENT_SECRET=
# When using agent, set CTF_INSTANCE_HOST to the AGENT server IP (players connect there)
#CTF_INSTANCE_HOST=YOUR_AGENT_SERVER_IP
# Platform's own URL as seen FROM the agent server (used to download challenge ZIPs).
# Set to http://<PLATFORM_SERVER_IP>:8080 — must be reachable from the agent host.
#PLATFORM_INTERNAL_URL=http://YOUR_PLATFORM_SERVER_IP:8080
