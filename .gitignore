cat .gitignore
# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.jks

# ── Java / Maven ──────────────────────────────────────────────────────────────
Backend/target/
Backend/logs/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
hs_err_pid*

# ── Node / Next.js ────────────────────────────────────────────────────────────
Frontend/node_modules/
Frontend/.next/
Frontend/out/
Frontend/.env.local
Frontend/.env.development.local
Frontend/.env.test.local
Frontend/.env.production.local
Frontend/tsconfig.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker / runtime ──────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / editors ─────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Uploads / challenge data ──────────────────────────────────────────────────
ctf-uploads/
*.zip
!docker/db/*.sql

# ── CTFd reference (not part of the platform) ────────────────────────────────
CTFd-master/

# ── Misc junk files ───────────────────────────────────────────────────────────
*.png
*.tmp
EXTRACTION_PLAN.md
IwillNeedThisForProduction.txt
design-files/
logo-files/
